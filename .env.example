# PostgreSQL Configuration
POSTGRES_HOST=<your-host>
POSTGRES_PORT=<your-port>
POSTGRES_DB=<your-db-name>
POSTGRES_USER=<your-user>
POSTGRES_PASSWORD=<your-password>

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
AWS_S3_ENDPOINT_URL=http://minio:9000

# Container registry coordinates for production deployments
DOCKER_REGISTRY=ghcr.io
DOCKER_NAMESPACE=your-org-or-user
IMAGE_TAG=latest

# Airflow Configuration
# UID and GID for Airflow containers to match host user,
# preventing permission issues on mounted volumes.
# You can find your UID and GID by running `id -u` and `id -g` in your terminal.
AIRFLOW_UID=50000
AIRFLOW_GID=50000

# Airflow Webserver Port
AIRFLOW_WEBSERVER_PORT=8080

# Airflow Database Connection (for Airflow's metadata DB)
# This usually points to the same PostgreSQL service or a dedicated one
AIRFLOW_DB_HOST=<your-host>
AIRFLOW_DB_PORT=<your-port>
AIRFLOW_DB_NAME=<your-db-name>
AIRFLOW_DB_USER=<your-user>
AIRFLOW_DB_PASSWORD=<your-password>

# Airflow Fernet Key for encrypting sensitive information
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=

# Airflow default user credentials (for local development)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
